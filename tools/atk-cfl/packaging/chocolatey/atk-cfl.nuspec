  <metadata>
    <id>atk-cfl</id>
    <version>0.0.0</version>
    <title>Confluence CLI</title>
    <authors>wohsj110</authors>
    <owners>rianjs</owners>
    <licenseUrl>https://github.com/wohsj110/atlassian_cli/blob/main/tools/atk-cfl/LICENSE</licenseUrl>
